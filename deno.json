{
	"name": "grab",
	"description": "A modern find replcement.",
	"version": "0.1.0",
	"license": "gpl-v3",
	"tasks": {
		"dev": "deno run --allow-read src/main.ts",
		"compile": "deno compile --allow-read --output grab src/main.ts",
		"compile:linux-x64": "deno compile --allow-read --allow-env --output grab-linux-x64 --target x86_64-unknown-linux-gnu src/main.ts",
		"compile:linux-arm": "deno compile --allow-read --allow-env --output grab-linux-arm --target aarch64-unknown-linux-gnu src/main.ts",
		"compile:mac-x64": "deno compile --allow-read --allow-env --output grab-mac-x64 --target x86_64-apple-darwin src/main.ts",
		"compile:mac-arm": "deno compile --allow-read --allow-env --output grab-mac-arm --target aarch64-apple-darwin src/main.ts",
		"compile:win-x64": "deno compile --allow-read --allow-env --output grab-win-x64.exe --target x86_64-pc-windows-msvc src/main.ts",
		"compile:all": "deno task compile:linux-x64 && deno task compile:linux-arm && deno task compile:mac-x64 && deno task compile:mac-arm && deno task compile:win-x64"
	},
	"exports": "./src/main.ts",
	"imports": {
		"commander": "npm:commander@12",
		"@std/walk": "jsr:@std/fs@1/walk",
		"@std/path": "jsr:@std/path@1",
		"@std/assert": "jsr:@std/assert@1"
	},
	"compilerOptions": {
		"strict": true,
		"noImplicitAny": true,
		"noUnusedLocals": true
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 120,
		"indentWidth": 4,
		"semiColons": false,
		"singleQuote": false
	},
	"lint": {
		"rules": {
			"include": [
				"no-unused-vars",
				"eqeqeq"
			]
		}
	}
}
